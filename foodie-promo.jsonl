{"type": "script", "parentId": "scene1-login", "content": "var p = ctx.frame / ctx.totalFrames;\nvar hero = ctx.getNode('login-hero');\nvar form = ctx.getNode('login-form');\nvar btn = ctx.getNode('login-btn');\nvar heroImg = ctx.getNode('login-hero-image');\nvar title = ctx.getNode('login-hero-title');\nvar subtitle = ctx.getNode('login-hero-subtitle');\nvar social = ctx.getNode('login-social');\nvar footer = ctx.getNode('login-footer');\nvar ease = function(t) { return t < 0 ? 0 : t > 1 ? 1 : t; };\nvar fadeIn = function(frame, delay, dur) { return ease((frame - delay) / dur); };\nhero.opacity(fadeIn(ctx.frame, 0, 15));\nheroImg.scale(0.5 + 0.5 * fadeIn(ctx.frame, 0, 12));\nheroImg.opacity(fadeIn(ctx.frame, 0, 12));\ntitle.opacity(fadeIn(ctx.frame, 5, 10));\ntitle.translateY(20 * (1 - fadeIn(ctx.frame, 5, 10)));\nsubtitle.opacity(fadeIn(ctx.frame, 8, 10));\nsubtitle.translateY(15 * (1 - fadeIn(ctx.frame, 8, 10)));\nform.opacity(fadeIn(ctx.frame, 12, 12));\nform.translateY(30 * (1 - fadeIn(ctx.frame, 12, 12)));\nbtn.scale(0.9 + 0.1 * fadeIn(ctx.frame, 18, 8));\nsocial.opacity(fadeIn(ctx.frame, 22, 10));\nsocial.translateY(20 * (1 - fadeIn(ctx.frame, 22, 10)));\nfooter.opacity(fadeIn(ctx.frame, 26, 10));"}
{"type": "script", "parentId": "scene2-home", "content": "var p = ctx.frame / ctx.totalFrames;\nvar ease = function(t) { return t < 0 ? 0 : t > 1 ? 1 : t; };\nvar fadeIn = function(frame, delay, dur) { return ease((frame - delay) / dur); };\nvar header = ctx.getNode('home-header');\nvar search = ctx.getNode('home-search');\nvar cats = ctx.getNode('home-categories');\nvar featured = ctx.getNode('home-featured');\nvar nav = ctx.getNode('home-bottom-nav');\nheader.opacity(fadeIn(ctx.frame, 0, 10));\nheader.translateY(-20 * (1 - fadeIn(ctx.frame, 0, 10)));\nsearch.opacity(fadeIn(ctx.frame, 4, 10));\nsearch.scale(0.95 + 0.05 * fadeIn(ctx.frame, 4, 10));\ncats.opacity(fadeIn(ctx.frame, 10, 12));\ncats.translateY(25 * (1 - fadeIn(ctx.frame, 10, 12)));\nfeatured.opacity(fadeIn(ctx.frame, 16, 12));\nfeatured.translateY(30 * (1 - fadeIn(ctx.frame, 16, 12)));\nnav.opacity(fadeIn(ctx.frame, 22, 10));\nnav.translateY(40 * (1 - fadeIn(ctx.frame, 22, 10)));"}
{"type": "script", "parentId": "scene3-settings", "content": "var p = ctx.frame / ctx.totalFrames;\nvar ease = function(t) { return t < 0 ? 0 : t > 1 ? 1 : t; };\nvar fadeIn = function(frame, delay, dur) { return ease((frame - delay) / dur); };\nvar header = ctx.getNode('settings-header');\nvar profile = ctx.getNode('settings-profile');\nvar section = ctx.getNode('settings-section');\nvar logout = ctx.getNode('settings-logout');\nheader.opacity(fadeIn(ctx.frame, 0, 8));\nheader.translateX(-20 * (1 - fadeIn(ctx.frame, 0, 8)));\nprofile.opacity(fadeIn(ctx.frame, 4, 10));\nprofile.scale(0.9 + 0.1 * fadeIn(ctx.frame, 4, 10));\nsection.opacity(fadeIn(ctx.frame, 10, 14));\nsection.translateY(20 * (1 - fadeIn(ctx.frame, 10, 14)));\nlogout.opacity(fadeIn(ctx.frame, 18, 8));"}
