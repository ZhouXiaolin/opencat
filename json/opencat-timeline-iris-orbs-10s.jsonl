{"type":"script","parentId":"root","src":"var ids=['orb-1','orb-2','orb-3','orb-4','orb-5','orb-6','orb-7'];var faceIds=['orb-1-face','orb-2-face','orb-3-face','orb-4-face','orb-5-face','orb-6-face','orb-7-face'];var labelIds=['orb-1-tag','orb-2-tag','orb-3-tag','orb-4-tag','orb-5-tag','orb-6-tag','orb-7-tag'];var entry=ctx.fromTo(ids,{opacity:0,scale:0.42,y:90},{opacity:1,scale:1,y:0,duration:42,stagger:8,ease:'spring.wobbly'});var driftCfg=[{tx0:-10,tx1:12,ty0:-14,ty1:10,sc0:0.98,sc1:1.04,rot0:-4,rot1:3,duration:88,delay:0,c0:'#facc15',c1:'#fb7185'},{tx0:-12,tx1:10,ty0:-18,ty1:14,sc0:0.95,sc1:1.06,rot0:-3,rot1:4,duration:96,delay:5,c0:'#22c55e',c1:'#4ade80'},{tx0:-8,tx1:14,ty0:-12,ty1:8,sc0:0.97,sc1:1.05,rot0:-5,rot1:5,duration:82,delay:9,c0:'#38bdf8',c1:'#60a5fa'},{tx0:-14,tx1:12,ty0:-16,ty1:12,sc0:0.96,sc1:1.05,rot0:-4,rot1:4,duration:92,delay:12,c0:'#fb7185',c1:'#f43f5e'},{tx0:-10,tx1:16,ty0:-12,ty1:14,sc0:0.95,sc1:1.07,rot0:-3,rot1:5,duration:98,delay:16,c0:'#a855f7',c1:'#c084fc'},{tx0:-12,tx1:10,ty0:-14,ty1:10,sc0:0.97,sc1:1.04,rot0:-5,rot1:4,duration:86,delay:20,c0:'#fb923c',c1:'#fdba74'},{tx0:-8,tx1:12,ty0:-16,ty1:12,sc0:0.96,sc1:1.05,rot0:-4,rot1:4,duration:90,delay:24,c0:'#14b8a6',c1:'#2dd4bf'}];for(var i=0;i<ids.length;i++){var cfg=driftCfg[i];var entryState=entry[i];var drift=ctx.fromTo(ids[i],{x:cfg.tx0,y:cfg.ty0,scale:cfg.sc0,rotate:cfg.rot0},{x:cfg.tx1,y:cfg.ty1,scale:cfg.sc1,rotate:cfg.rot1,duration:cfg.duration,delay:cfg.delay,ease:'ease-in-out',repeat:-1,yoyo:true});var color=ctx.fromTo(ids[i],{bg:cfg.c0},{bg:cfg.c1,duration:cfg.duration+18,delay:cfg.delay,ease:'ease-in-out',repeat:-1,yoyo:true});var faceFloat=ctx.fromTo(faceIds[i],{y:-3,rotate:-1},{y:5,rotate:2,duration:54+i*4,delay:i*3,ease:'ease-in-out',repeat:-1,yoyo:true});var labelPulse=ctx.fromTo(labelIds[i],{scale:0.96,opacity:0.75},{scale:1.06,opacity:1,duration:46+i*3,delay:i*2,ease:'ease-in-out',repeat:-1,yoyo:true});ctx.getNode(ids[i]).opacity(entryState.opacity).scale(entryState.scale*drift.scale).translateX(drift.x).translateY(entryState.y+drift.y).rotate(drift.rotate).bg(color.bg);ctx.getNode(faceIds[i]).translateY(faceFloat.y).rotate(faceFloat.rotate);ctx.getNode(labelIds[i]).scale(labelPulse.scale).opacity(labelPulse.opacity);}"}
