{"type": "script", "parentId": "root", "src": "ctx.animate({targets:'stage',from:{opacity:0,scale:0.97},to:{opacity:1,scale:1},duration:24,easing:'spring-gentle'});ctx.animate({targets:'stage-title',from:{opacity:0,translateY:-12},to:{opacity:1,translateY:0},duration:20,delay:6,easing:'spring-gentle'});ctx.animate({targets:'stage-meta',from:{opacity:0,translateY:-12},to:{opacity:1,translateY:0},duration:20,delay:6,easing:'spring-gentle'});ctx.animate({targets:'footer-note',from:{opacity:0,translateY:8},to:{opacity:1,translateY:0},duration:18,delay:176,easing:'spring-gentle'});ctx.animate({targets:'ghost-api',from:{opacity:0.08,translateX:0},to:{opacity:0.16,translateX:-34},duration:140,easing:'ease-in-out',repeat:-1,yoyo:true});ctx.animate({targets:'orb-a',from:{opacity:0.12,translateX:-18,translateY:-12,scale:1},to:{opacity:0.18,translateX:28,translateY:20,scale:1.08},duration:120,easing:'ease-in-out',repeat:-1,yoyo:true});ctx.animate({targets:'orb-b',from:{opacity:0.12,translateX:0,translateY:0,scale:1},to:{opacity:0.18,translateX:22,translateY:-18,scale:1.06},duration:132,delay:10,easing:'ease-in-out',repeat:-1,yoyo:true});ctx.animate({targets:'orb-c',from:{opacity:0.1,translateX:0,translateY:0,scale:1},to:{opacity:0.16,translateX:-20,translateY:-24,scale:1.1},duration:110,delay:20,easing:'ease-in-out',repeat:-1,yoyo:true})"}
{"type": "script", "parentId": "grapheme-group", "src": "var shellIn=ctx.animate({from:{opacity:0,translateY:34,scale:0.98},to:{opacity:1,translateY:0,scale:1},duration:24,easing:'spring-gentle'});var shellOut=ctx.animate({from:{opacity:1,translateY:0,scale:1},to:{opacity:0,translateY:-30,scale:0.985},duration:20,delay:112,easing:'ease-in-out'});var shell=ctx.frame<112?shellIn:shellOut;ctx.getNode('grapheme-group').opacity(shell.opacity).translateY(shell.translateY).scale(shell.scale);ctx.animate({targets:'g1-kicker',from:{opacity:0,translateY:10},to:{opacity:1,translateY:0},duration:16,delay:4,easing:'spring-gentle'});ctx.animate({targets:'g1-code',from:{opacity:0,translateY:10},to:{opacity:1,translateY:0},duration:16,delay:4,easing:'spring-gentle'});ctx.animate({targets:'g1-note',from:{opacity:0,translateY:16},to:{opacity:1,translateY:0},duration:18,delay:22,easing:'spring-gentle'});ctx.splitTextNode('g1-title',{granularity:'graphemes'}).animate({from:{opacity:0,translateY:38,scale:0.86},to:{opacity:1,translateY:0,scale:1},duration:22,delay:8,stagger:2,easing:'spring-wobbly'})"}
