{"type": "script", "parentId": "runtime-group", "src": "ctx.animate({targets:'runtime-group',from:{opacity:0,translateY:34,scale:0.99},to:{opacity:1,translateY:0,scale:1},duration:24,delay:182,easing:'spring-gentle'});ctx.animate({targets:'g3-kicker',from:{opacity:0,translateY:8},to:{opacity:1,translateY:0},duration:16,delay:188,easing:'spring-gentle'});ctx.animate({targets:'g3-code',from:{opacity:0,translateY:8},to:{opacity:1,translateY:0},duration:16,delay:188,easing:'spring-gentle'});ctx.animate({targets:'g3-note',from:{opacity:0,translateY:12},to:{opacity:1,translateY:0},duration:18,delay:210,easing:'spring-gentle'});ctx.getNode('runtime-title').text('text() first, then split');ctx.splitTextNode('runtime-title',{granularity:'words'}).animate({from:{opacity:0,translateX:16,translateY:26,scale:0.94},to:{opacity:1,translateX:0,translateY:0,scale:1},duration:20,delay:196,stagger:5,easing:'spring-wobbly'})"}
