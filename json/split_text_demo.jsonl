{"type":"script","parentId":"root","src":"var charDirs=[[-260,-170],[0,-230],[230,-160],[-260,0],[260,0],[-180,190],[0,230],[190,190],[-310,120],[310,-120],[0,-280]];ctx.fromTo(ctx.splitText('char-text',{type:'chars'}),{opacity:0,x:function(i){return charDirs[i%charDirs.length][0];},y:function(i){return charDirs[i%charDirs.length][1];},scale:0.72,rotate:function(i){return i%2===0?-18:18;}},{opacity:1,x:0,y:0,scale:1,rotate:0,duration:54,stagger:2,ease:'spring.gentle'});var wordDirs=[[-360,-120],[0,0],[360,120]];ctx.fromTo(ctx.splitText('word-text',{type:'words'}),{opacity:function(i,t){return t.text.trim().length===0?1:0;},x:function(i){return wordDirs[i%wordDirs.length][0];},y:function(i){return wordDirs[i%wordDirs.length][1];},scale:function(i,t){return t.text.trim().length===0?1:0.78;},rotate:function(i,t){return t.text.trim().length===0?0:(i===0?-10:10);}},{opacity:1,x:0,y:0,scale:1,rotate:0,duration:64,delay:8,stagger:8,ease:'spring.gentle'});"}
