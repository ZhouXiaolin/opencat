{
  "name": "opencat-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && vite",
    "build:wasm": "cd ../crates/opencat-web && wasm-pack build --target web --out-dir ../../web/wasm",
